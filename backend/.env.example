# Environment Variables for BharatPath Backend
# Copy this file to .env and fill in your actual keys for deployment.

# 1. MongoDB Atlas Connection
MONGO_URI=

# 2. Authenticaton (Google Cloud Console OAuth 2.0)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
JWT_SECRET=a_random_secure_string_for_tokens

# 3. Railway API 
PNR_API_KEY=
PNR_API_HOST=

LIVE_STATUS_API_KEY=
LIVE_STATUS_API_HOST=

TRAIN_SEARCH_API_KEY=
TRAIN_SEARCH_API_HOST=

STATION_SEARCH_API_KEY=
STATION_SEARCH_API_HOST=
# 4. Routing
PORT=5000
FRONTEND_URL=http://localhost:5173
